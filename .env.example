# Groq LLM API Configuration (Recommended)
# Get your API key from: https://console.groq.com/
# Used for:
#   - LLM classification fallback when ML confidence is low
#   - AI-generated action recommendations
#   - Complete resolution generation (root cause + steps)
# The system has basic fallback without this, but much better with it!
GROQ_API_KEY=your_groq_api_key_here

# LLM Model Selection (Optional)
# Default: llama-3.3-70b-versatile
# Available models: llama-3.3-70b-versatile, llama-3.1-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
LLM_MODEL=llama-3.3-70b-versatile

# ML Confidence Threshold (Optional)
# Default: 0.65 (65%)
# If ML prediction confidence is below this, system will use LLM fallback
# Range: 0.0 to 1.0
CONFIDENCE_THRESHOLD=0.65
